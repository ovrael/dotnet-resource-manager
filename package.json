{
  "name": "dotnet-resource-manager",
  "displayName": "DotNet Resource Manager",
  "description": "Helps with managing dotnet localization resources",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/*.sln",
    "workspaceContains:**/*.csproj",
    "workspaceContains:**/*.Designer.cs",
    "workspaceContains:**/*.resx"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "DotNet Resource Manager Settings",
      "properties": {
        "dotnet-resource-manager.createDirectory": {
          "type": "string",
          "default": "",
          "description": "Directory where new resource files will be created, leave if you want to be asked every time where to create."
        }
      }
    },
    "configurationDefaults": {
      "explorer.fileNesting.enabled": true,
      "explorer.fileNesting.patterns": {
        "*.resx": "${capture}.*.resx"
      }
    },
    "commands": [
      {
        "command": "dotnet-resource-manager.setDefaultCreateDirectory",
        "title": "Set default create directory"
      },
      {
        "command": "dotnet-resource-manager.createResourceFiles",
        "title": "Create Resource Files"
      }
    ],
    "customEditors": [
      {
        "viewType": "dotnet-resource-manager.resourceEditor",
        "displayName": "DotNet Resource Editor",
        "selector": [
          {
            "filenamePattern": "*.resx"
          },
          {
            "filenamePattern": "*.Designer.cs"
          }
        ],
        "priority": "default"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "resourceFilesView",
          "name": "Resource Files",
          "icon": "file",
          "contextualTitle": "Resource Files"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.11",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}